// ─── GROQ KI ANALYSE ─────────────────────────────────────────────────────────
async function analyzeJobWithAI(title, description, source) {
try {
const prompt = `Du bist ein Experte für Freelance Web-Entwicklung. Analysiere diesen Job-Post:

Titel: ${title}
Quelle: ${source}
Beschreibung: ${description?.slice(0, 800) || ‘Keine Beschreibung’}

Antworte NUR in diesem JSON-Format (kein Markdown, nur reines JSON):
{
“bewertung”: <Zahl 1-10>,
“zusammenfassung”: “<2-3 Sätze was gesucht wird>”,
“budget”: “<Budget falls erwähnt, sonst Nicht angegeben>”,
“aufwand”: “<Klein/Mittel/Groß>”,
“empfehlung”: “<Ja/Nein + kurze Begründung>”
}`;

```
const response = await fetch('https://api.groq.com/openai/v1/chat/completions', {
  method: 'POST',
  headers: {
    'Authorization': `Bearer ${GROQ_API_KEY}`,
    'Content-Type': 'application/json',
  },
  body: JSON.stringify({
    model: 'llama-3.1-8b-instant',
    max_tokens: 400,
    messages: [{ role: 'user', content: prompt }],
  }),
});

const data = await response.json();
const text = data.choices?.[0]?.message?.content || '';
const jsonMatch = text.match(/\{[\s\S]*\}/);
if (!jsonMatch) return null;
return JSON.parse(jsonMatch[0]);
```

} catch (err) {
console.error(‘Groq Fehler:’, err.message);
return null;
}
}

// ─── NACHRICHT FORMATIEREN ────────────────────────────────────────────────────
function escapeMarkdown(text) {
if (!text) return ‘’;
return String(text).replace(/[_*[]()~`>#+=|{}.!-]/g, ‘\$&’);
}

function formatMessage(item, analysis, feedName) {
const rating = analysis.bewertung;
const stars = ‘⭐’.repeat(Math.min(rating, 10));
const ratingEmoji = rating >= 8 ? ‘🔥’ : rating >= 6 ? ‘✅’ : ‘⚠️’;

return `${ratingEmoji} *Neuer Job gefunden\!*
📌 *${escapeMarkdown(item.title)}*

📊 *Bewertung:* ${stars} \(${rating}/10\)
📝 *Zusammenfassung:* ${escapeMarkdown(analysis.zusammenfassung)}
💰 *Budget:* ${escapeMarkdown(analysis.budget)}
⏱ *Aufwand:* ${escapeMarkdown(analysis.aufwand)}
✉️ *Empfehlung:* ${escapeMarkdown(analysis.empfehlung)}

🌐 *Quelle:* ${escapeMarkdown(feedName)}
🔗 [Job ansehen](${item.link})`;
}

// ─── FEEDS PRÜFEN ─────────────────────────────────────────────────────────────
let isFirstRun = true;

async function checkFeeds() {
console.log(`\n[${new Date().toLocaleTimeString()}] Prüfe ${RSS_FEEDS.length} Feeds...`);
let newJobs = 0;

for (const feed of RSS_FEEDS) {
try {
const parsed = await parser.parseURL(feed.url);
const items = parsed.items?.slice(0, 10) || [];

```
  for (const item of items) {
    const jobId = item.guid || item.link || item.title;
    if (!jobId || seenJobs.has(jobId)) continue;
    seenJobs.add(jobId);
    if (isFirstRun) continue;

    console.log(`  → Analysiere: ${item.title?.slice(0, 60)}...`);

    const analysis = await analyzeJobWithAI(
      item.title,
      item.contentSnippet || item.content || item.summary,
      feed.name
    );

    if (!analysis) continue;
    if (analysis.bewertung < MIN_RATING) {
      console.log(`  → Übersprungen (Bewertung: ${analysis.bewertung}/${MIN_RATING})`);
      continue;
    }

    const message = formatMessage(item, analysis, feed.name);
    await bot.sendMessage(CHAT_ID, message, {
      parse_mode: 'MarkdownV2',
      disable_web_page_preview: false,
    });

    newJobs++;
    await new Promise(r => setTimeout(r, 2000));
  }
} catch (err) {
  console.error(`  ✗ Fehler bei ${feed.name}:`, err.message);
}
```

}

if (!isFirstRun) {
console.log(`  ✓ ${newJobs} neue Jobs gesendet`);
}
}

