// ─── START ────────────────────────────────────────────────────────────────────
async function start() {
console.log(‘🤖 Freelance Job Bot startet…’);
console.log(`📡 ${RSS_FEEDS.length} Feeds | ⭐ Min: ${MIN_RATING}/10 | ⏱ alle ${CHECK_INTERVAL} Min\n`);

await checkFeeds();
isFirstRun = false;
console.log(`✅ ${seenJobs.size} bestehende Jobs markiert. Warte auf neue...\n`);

try {
await bot.sendMessage(CHAT_ID,
`🚀 *Freelance Bot ist online\\!*\n` +
`Überwache ${RSS_FEEDS.length} Feeds alle ${CHECK_INTERVAL} Minuten\\.`,
{ parse_mode: ‘MarkdownV2’ }
);
} catch (e) {
console.error(‘Telegram Fehler:’, e.message);
}

cron.schedule(`*/${CHECK_INTERVAL} * * * *`, checkFeeds);
}

start().catch(console.error);
